# 复制本文件为 .env 后填写。勿将 .env 提交到版本库。
#
# 控制端 /admin 与 GET /api/scenes、GET /api/items、POST /api/scene、GET /api/share/* 等
# （未设置则不做页面/API 口令保护；详见 README「口令与 API 鉴权」）
ADMIN_PASSWORD=

# 编辑端 /editor 与草稿/保存/发布/上传 API（留空则与 ADMIN_PASSWORD 相同）
EDITOR_PASSWORD=

# Cookie 签名密钥（未设置则使用代码内占位，仅适合本机；生产务必改为随机长字符串）
WORSHIP_AUTH_SECRET=

# 会众端完整 URL（管理端「分享」生成二维码用，手机扫码访问；例：https://你的域名或IP:端口/view）
# PUBLIC_VIEW_URL=https://example.com/view

# 可选：HTTP 端口
# PORT=3002
